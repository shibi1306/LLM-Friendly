{
  "manifest_version": 3,
  "name": "LLM Friendly",
  "version": "1.0.0",
  "description": "Transform documents into AI-friendly Markdown directly within supported AI chat websites.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LLM Friendly"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://chat.mistral.ai/*",
        "https://mistral.ai/*",
        "https://poe.com/*",
        "https://chat.deepseek.com/*",
        "https://aistudio.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://huggingface.co/chat/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "downloads", "activeTab", "scripting", "offscreen", "alarms"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://tessdata.projectnaptha.com"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.worker.js",
        "tesseract-worker.min.js",
        "tesseract-core.wasm.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
