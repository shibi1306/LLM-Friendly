{
  "manifest_version": 3,
  "name": "MarkItDown Converter",
  "version": "1.0.0",
  "description": "Convert PDF, DOCX, XLSX, PPTX, HTML, CSV and more to Markdown directly in your browser on any AI chat site.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MarkItDown Converter"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://chat.deepseek.com/*",
        "https://aistudio.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://huggingface.co/chat/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "downloads", "activeTab", "tabs", "scripting"],
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "markitdown-converter@extension",
      "strict_min_version": "109.0"
    }
  }
}
