{
  "name": "markitdown-browser-extension",
  "version": "1.0.0",
  "description": "Convert PDF, DOCX, XLSX, images and more to Markdown on any AI chat site",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "webpack --mode production --env browser=chrome",
    "build:firefox": "webpack --mode production --env browser=firefox",
    "build:safari": "npm run build:chrome && npm run safari:convert",
    "safari:convert": "xcrun safari-web-extension-converter dist --app-name 'MarkItDown Converter' --bundle-identifier com.markitdown.converter --macos-only --force",
    "dev": "webpack --mode development --watch --env browser=chrome",
    "dev:firefox": "webpack --mode development --watch --env browser=firefox",
    "icons": "node scripts/generate-icons.js",
    "package:chrome": "cd dist && zip -r ../markitdown-chrome.zip .",
    "package:firefox": "cd dist-firefox && zip -r ../markitdown-firefox.xpi .",
    "package:all": "npm run build && npm run package:chrome && npm run package:firefox"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "fflate": "^0.8.2",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^3.11.174",
    "turndown": "^7.2.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "mini-css-extract-plugin": "^2.9.0",
    "webextension-polyfill": "^0.12.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
